# Environment
NODE_ENV=development
PORT=3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/company-knowledge


# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# BullMQ (for jobs)
BULLMQ_REDIS_URL=redis://localhost:6379

# Email (if using for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Logging
LOG_LEVEL=info