{
  "name": "company-knowledge-backend",
  "version": "1.0.0",
  "description": "Company Knowledge Backend",
  "main": "dist/server.js",
  "ts-node": {
    "files": true,
    "require": [
      "tsconfig-paths/register"
    ]
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "dev": "nodemon -r tsconfig-paths/register --exec ts-node --project tsconfig.json src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "seed:template": "ts-node src/seeds/seedMasterTemplate.ts"
  },
  "keywords": [
    "company",
    "knowledge",
    "backend",
    "typescript"
  ],
  "author": "<Sunil>",
  "license": "ISC",
  "dependencies": {
    "@langchain/openai": "^1.2.12",
    "@langchain/textsplitters": "^1.0.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.65.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.30",
    "mime-types": "^3.0.2",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.11",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
